{
	"name": "@canvist/canvist",
	"version": "0.1.0",
	"license": "Unlicense",
	"exports": "./src/mod.ts",
	"publish": {
		"include": [
			"src/**/*.ts",
			"wasm/**/*.js",
			"wasm/**/*.wasm",
			"wasm/**/*.d.ts",
			"README.md"
		],
		"exclude": ["**/*_test.ts", "tests/"]
	},
	"tasks": {
		"build:wasm": "cd ../.. && wasm-pack build crates/canvist_wasm --target web --out-dir ../../packages/canvist/wasm",
		"test": "deno test --allow-read --allow-net --allow-env --allow-run tests/",
		"test:unit": "deno test --allow-read --allow-net --allow-env --allow-run",
		"test:playwright": "deno test --allow-read --allow-write --allow-net --allow-env --allow-run --allow-sys tests/playwright/**/*.spec.ts",
		"ci:test": "deno task test:unit && deno task test:playwright"
	},
	"imports": {
		"@std/assert": "jsr:@std/assert@^1",
		"@std/path": "jsr:@std/path@^1",
		"@std/http": "jsr:@std/http@^1"
	},
	"compilerOptions": {
		"lib": ["deno.window", "dom", "dom.iterable"]
	}
}
